POSTGRES_DB=licitacoes
POSTGRES_USER=licitacoes
POSTGRES_PASSWORD=licitacoes
DATABASE_URL=postgresql://licitacoes:licitacoes@localhost:5432/licitacoes

# ── Provedor de classificação ─────────────────────────────────────────────────
# "gemini"    → Google Gemini 2.0 Flash — GRATUITO (1500 req/dia)
#               Obter chave: aistudio.google.com → Get API key (conta Google basta)
# "anthropic" → Claude (pago, alta precisão para produção)
CLASSIFIER_PROVIDER=gemini
GEMINI_API_KEY=

# Apenas se CLASSIFIER_PROVIDER=anthropic:
ANTHROPIC_API_KEY=sk-ant-...
# Opcional: claude-haiku-4-5 reduz custo em produção (padrão: claude-opus-4-8)
CLASSIFIER_MODEL=claude-opus-4-8

# Modelo Gemini (padrão: gemini-2.0-flash, também gratuito: gemini-1.5-flash)
GEMINI_MODEL=gemini-2.0-flash

# Limiar de confiança abaixo do qual o edital vai para revisão manual (padrão: 0.6)
CONFIANCA_MINIMA=0.6

# Horários do cron diário (formato HH:MM, 24h)
CRON_HORA_PNCP=07:00
CRON_HORA_DIARIOS=07:30
CRON_UF=SP         # UF de fallback quando nenhum cliente tem região configurada
CRON_PAGINAS=5
CRON_DIAS=1

# Telegram Bot (obter em @BotFather)
TELEGRAM_BOT_TOKEN=
# ID do chat/grupo para receber alertas
# Como obter: envie /start ao bot, acesse https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
